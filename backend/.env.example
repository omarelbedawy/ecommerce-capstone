# Copy this file to .env and fill in real values before running

# Postgres connection - matches docker-compose service by default
DATABASE_URL="postgresql://ecommerce_user:ecommerce_pass@localhost:5432/ecommerce_db?schema=public"

PORT=5000

# JWT
JWT_SECRET=change_this_to_something_long_and_random
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change_this_too_please
REFRESH_TOKEN_EXPIRES_IN=7d

# Ethereal test email (fake SMTP inbox, no real account needed)
# Get one free at https://ethereal.email - click "Create Ethereal Account"
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=your_ethereal_user
EMAIL_PASS=your_ethereal_pass

FRONTEND_URL=http://localhost:5173
